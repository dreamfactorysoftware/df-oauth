{
  "name":        "dreamfactory/df-oauth",
  "description": "OAuth support for DreamFactory Platform 2.0",
  "keywords":    [
    "dreamfactory",
    "api",
    "rest",
    "oauth"
  ],
  "homepage":    "https://www.dreamfactory.com/",
  "license":     "Apache-2.0",
  "authors":     [
    {
      "name":  "Arif Islam",
      "email": "arifislam@dreamfactory.com"
    },
    {
      "name":  "Lee Hicks",
      "email": "leehicks@dreamfactory.com"
    }
  ],
  "support":     {
    "email":  "dspsupport@dreamfactory.com",
    "source": "https://github.com/dreamfactorysoftware/df-oauth",
    "issues": "https://github.com/dreamfactorysoftware/df-oauth/issues",
    "wiki":   "https://wiki.dreamfactory.com"
  },
  "minimum-stability": "dev",
  "prefer-stable":     true,
  "require":     {
    "php":                               "^8.3",
    "ext-json":                          "*",
    "laravel/helpers":                   "^1.8",
    "dreamfactory/df-core":              "~1.0.4",
    "laravel/socialite":                 "^5.20",
    "socialiteproviders/microsoft-live": "^4.1",
    "socialiteproviders/twitter":        "^4.1"
  },
  "require-dev": {
    "laravel/framework":     "^13.7",
    "mockery/mockery":       "^1.6",
    "nunomaduro/collision":  "^8.6",
    "phpunit/phpunit":       "^11.5.3",
    "orchestra/testbench":   "^11.0"
  },
  "autoload":    {
    "psr-4": {
      "DreamFactory\\Core\\OAuth\\": "src/"
    }
  },
  "extra":       {
    "branch-alias": {
      "dev-develop": "0.14.x-dev"
    },
    "laravel": {
      "providers": [
        "DreamFactory\\Core\\OAuth\\ServiceProvider"
      ]
    }
  }
}
